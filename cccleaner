#!/usr/bin/env bash

# Claude Code Cleaner - Clean history from ~/.claude.json
# Usage: ./cccleaner.sh [options]

set -euo pipefail

CLAUDE_JSON="$HOME/.claude.json"
CLAUDE_DIR="$HOME/.claude"
BACKUP_DIR="$HOME/.claude_backups"
TZ_LAUNCH_AGENT_LABEL="com.cccleaner.env-tz"
TZ_LAUNCH_AGENT_PATH="$HOME/Library/LaunchAgents/${TZ_LAUNCH_AGENT_LABEL}.plist"
US_TIMEZONE="America/Los_Angeles"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if jq is installed
check_dependencies() {
    if ! command -v jq &> /dev/null; then
        print_error "jq is required but not installed. Please install it:"
        echo "  macOS: brew install jq"
        echo "  Linux: apt-get install jq or yum install jq"
        exit 1
    fi
}

# Create backup of .claude.json and .claude directory
create_claude_backup() {
    mkdir -p "$BACKUP_DIR"
    local timestamp=$(date +%Y%m%d_%H%M%S)

    # Backup .claude.json if exists
    if [ -f "$CLAUDE_JSON" ]; then
        local backup_file="$BACKUP_DIR/claude_$(basename "$CLAUDE_JSON")_$timestamp"
        cp "$CLAUDE_JSON" "$backup_file"
        print_success "Backup created: $backup_file"
    fi

    # Backup .claude directory if exists
    if [ -d "$CLAUDE_DIR" ]; then
        local backup_dir="$BACKUP_DIR/claude_dir_$timestamp"
        cp -r "$CLAUDE_DIR" "$backup_dir"
        print_success "Backup created: $backup_dir"
    fi

}

# Create backup of shell TZ overrides and LaunchAgent
create_timezone_backup() {
    mkdir -p "$BACKUP_DIR"
    local timestamp=$(date +%Y%m%d_%H%M%S)

    backup_timezone_files "$timestamp"
}

# Show usage
show_usage() {
    cat << EOF
Claude Code Cleaner - Clean history from ~/.claude.json

Usage: $(basename "$0") [options]

Options:
    -a, --all              Clean everything (histories + projects + folders + cache + githubRepoPaths + history.jsonl + counters + usage stats + identity IDs)
    -p, --project PATH     Clear history for specific project path
    -l, --list             List all projects
    -i, --interactive      Interactive mode to select projects
    -c, --cache            Clear cached data (changelog, etc.)
    -g, --github-repos     Clear GitHub repository paths
    -f, --folders          Clear ~/.claude folder contents (file-history, projects, todos, shell-snapshots, statsig, debug, session-env, history.jsonl)
    -u, --user-id          Regenerate identity IDs in ~/.claude.json (userID + anonymousId)
    --set-us-timezone      Set TZ=America/Los_Angeles in shell files and macOS LaunchAgent
    --unset-timezone       Remove TZ overrides from shell files and macOS LaunchAgent
    -h, --help             Show this help message
    --no-backup            Skip backup creation (not recommended)

Note: --all also resets numStartups, btwUseCount, promptQueueUseCount, tipsHistory, opus1mMergeNoticeSeenCount, voiceNoticeSeenCount, firstStartTime, claudeCodeFirstTokenDate, skillUsage, toolUsage, and regenerates userID plus anonymousId

Examples:
    $(basename "$0") --list
    $(basename "$0") --all
    $(basename "$0") --folders
    $(basename "$0") --github-repos
    $(basename "$0") --user-id
    $(basename "$0") --set-us-timezone
    $(basename "$0") --unset-timezone
    $(basename "$0") --project /Users/user/myproject
    $(basename "$0") --interactive

EOF
}

# Back up shell files and LaunchAgent if they contain cccleaner's US timezone override
backup_timezone_files() {
    local timestamp="$1"
    local backup_dir=""
    local file
    local shell_files=(
        "$HOME/.zshenv"
        "$HOME/.zprofile"
        "$HOME/.bash_profile"
        "$HOME/.bashrc"
        "$HOME/.profile"
        "$HOME/.zshrc"
    )

    for file in "${shell_files[@]}"; do
        if [ -f "$file" ]; then
            if grep -Eq '^[[:space:]]*export[[:space:]]+TZ="America/Los_Angeles"[[:space:]]*$' "$file"; then
                if [ -z "$backup_dir" ]; then
                    backup_dir="$BACKUP_DIR/timezone_override_$timestamp"
                    mkdir -p "$backup_dir"
                fi
                cp "$file" "$backup_dir/$(basename "$file")"
                print_success "Backup created: $backup_dir/$(basename "$file")"
            fi
        fi
    done

    if [ -f "$TZ_LAUNCH_AGENT_PATH" ]; then
        if [ -z "$backup_dir" ]; then
            backup_dir="$BACKUP_DIR/timezone_override_$timestamp"
            mkdir -p "$backup_dir"
        fi
        cp "$TZ_LAUNCH_AGENT_PATH" "$backup_dir/$(basename "$TZ_LAUNCH_AGENT_PATH")"
        print_success "Backup created: $backup_dir/$(basename "$TZ_LAUNCH_AGENT_PATH")"
    fi
}

# List all projects
list_projects() {
    print_info "Projects in $CLAUDE_JSON:"
    echo
    jq -r '.projects | keys[] | "  \(.)"' "$CLAUDE_JSON" 2>/dev/null || {
        print_error "Failed to read projects from $CLAUDE_JSON"
        exit 1
    }
}

# Clear all project histories
clear_all_histories() {
    local temp_file=$(mktemp)

    jq '.projects |= with_entries(.value.history = [])' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Cleared all project histories"
    else
        rm -f "$temp_file"
        print_error "Failed to clear histories"
        exit 1
    fi
}

# Clear specific project history
clear_project_history() {
    local project_path="$1"
    local temp_file=$(mktemp)

    # Check if project exists
    if ! jq -e --arg path "$project_path" '.projects | has($path)' "$CLAUDE_JSON" > /dev/null 2>&1; then
        print_error "Project not found: $project_path"
        rm -f "$temp_file"
        exit 1
    fi

    jq --arg path "$project_path" '.projects[$path].history = []' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Cleared history for: $project_path"
    else
        rm -f "$temp_file"
        print_error "Failed to clear history for: $project_path"
        exit 1
    fi
}

# Delete specific project entirely
delete_project() {
    local project_path="$1"
    local temp_file=$(mktemp)

    # Check if project exists
    if ! jq -e --arg path "$project_path" '.projects | has($path)' "$CLAUDE_JSON" > /dev/null 2>&1; then
        print_error "Project not found: $project_path"
        rm -f "$temp_file"
        exit 1
    fi

    jq --arg path "$project_path" 'del(.projects[$path])' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Deleted project: $project_path"
    else
        rm -f "$temp_file"
        print_error "Failed to delete project: $project_path"
        exit 1
    fi
}

# Clear all projects entirely
clear_all_projects() {
    local temp_file=$(mktemp)

    jq '.projects = {}' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Cleared all projects"
    else
        rm -f "$temp_file"
        print_error "Failed to clear all projects"
        exit 1
    fi
}

# Clear cached data
clear_cache() {
    local temp_file=$(mktemp)

    jq '
        del(.cachedChangelog, .cachedStatsigGates, .cachedDynamicConfigs, .cachedGrowthBookFeatures, .metricsStatusCache, .clientDataCache, .hasShownOpus45Notice)
        | if has("groveConfigCache") then .groveConfigCache = {} else . end
        | if has("passesEligibilityCache") then .passesEligibilityCache = {} else . end
        | if has("s1mAccessCache") then .s1mAccessCache = {} else . end
        | if has("lastPlanModeUse") then .lastPlanModeUse = 0 else . end
        | if has("passesUpsellSeenCount") then .passesUpsellSeenCount = 0 else . end
    ' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Cleared cached data"
    else
        rm -f "$temp_file"
        print_error "Failed to clear cache"
        exit 1
    fi
}

# Clear GitHub repo paths
clear_github_repo_paths() {
    local temp_file=$(mktemp)

    jq 'del(.githubRepoPaths)' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Cleared githubRepoPaths"
    else
        rm -f "$temp_file"
        print_error "Failed to clear githubRepoPaths"
        exit 1
    fi
}

# Write file only when content changed
write_if_changed() {
    local candidate="$1"
    local target="$2"

    if [ -f "$target" ] && cmp -s "$candidate" "$target"; then
        rm -f "$candidate"
        return 1
    fi

    mv "$candidate" "$target"
    return 0
}

# Remove export TZ lines from a shell file
remove_tz_exports() {
    local file="$1"
    local candidate

    if [ ! -f "$file" ]; then
        return 1
    fi

    candidate=$(mktemp)

    awk '
        /^[[:space:]]*export[[:space:]]+TZ=/ { next }
        { lines[++n] = $0 }
        END {
            while (n > 0 && lines[n] ~ /^[[:space:]]*$/) {
                n--
            }
            for (i = 1; i <= n; i++) {
                print lines[i]
            }
            if (n > 0) {
                printf "\n"
            }
        }
    ' "$file" > "$candidate"

    write_if_changed "$candidate" "$file"
}

# Add export TZ at the top of a shell file
ensure_tz_export_at_top() {
    local file="$1"
    local timezone="$2"
    local filtered
    local candidate

    mkdir -p "$(dirname "$file")"
    [ -f "$file" ] || : > "$file"

    filtered=$(mktemp)
    candidate=$(mktemp)

    awk '
        /^[[:space:]]*export[[:space:]]+TZ=/ { next }
        !started && /^[[:space:]]*$/ { next }
        {
            started = 1
            print
        }
    ' "$file" > "$filtered"

    {
        printf 'export TZ="%s"\n' "$timezone"
        printf '\n'
        cat "$filtered"
    } > "$candidate"

    rm -f "$filtered"
    write_if_changed "$candidate" "$file"
}

# Add export TZ at the end of a shell file as a tail guard
ensure_tz_export_at_end() {
    local file="$1"
    local timezone="$2"
    local filtered
    local candidate

    mkdir -p "$(dirname "$file")"
    [ -f "$file" ] || : > "$file"

    filtered=$(mktemp)
    candidate=$(mktemp)

    awk '
        /^[[:space:]]*export[[:space:]]+TZ=/ { next }
        { lines[++n] = $0 }
        END {
            while (n > 0 && lines[n] ~ /^[[:space:]]*$/) {
                n--
            }
            for (i = 1; i <= n; i++) {
                print lines[i]
            }
        }
    ' "$file" > "$filtered"

    {
        if [ -s "$filtered" ]; then
            cat "$filtered"
            printf '\n\n'
        fi
        printf 'export TZ="%s"\n' "$timezone"
    } > "$candidate"

    rm -f "$filtered"
    write_if_changed "$candidate" "$file"
}

# Write macOS LaunchAgent used for session TZ override
write_timezone_launch_agent() {
    local timezone="$1"

    if [ "$(uname -s)" != "Darwin" ]; then
        return 0
    fi

    mkdir -p "$(dirname "$TZ_LAUNCH_AGENT_PATH")"

    cat > "$TZ_LAUNCH_AGENT_PATH" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${TZ_LAUNCH_AGENT_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>launchctl</string>
    <string>setenv</string>
    <string>TZ</string>
    <string>${timezone}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
EOF
}

# Refresh the current macOS login session TZ override
refresh_launchctl_timezone() {
    local timezone="$1"
    local gui_domain

    if [ "$(uname -s)" != "Darwin" ]; then
        return 0
    fi

    if ! command -v launchctl > /dev/null 2>&1; then
        print_warning "launchctl not found, skipped macOS session timezone sync"
        return 0
    fi

    launchctl setenv TZ "$timezone" > /dev/null 2>&1 || print_warning "Failed to update launchctl TZ"

    gui_domain="gui/$(id -u)"
    launchctl bootout "$gui_domain" "$TZ_LAUNCH_AGENT_PATH" > /dev/null 2>&1 || true
    launchctl bootstrap "$gui_domain" "$TZ_LAUNCH_AGENT_PATH" > /dev/null 2>&1 || print_warning "Failed to bootstrap LaunchAgent ${TZ_LAUNCH_AGENT_LABEL}"
    launchctl kickstart -k "${gui_domain}/${TZ_LAUNCH_AGENT_LABEL}" > /dev/null 2>&1 || print_warning "Failed to kickstart LaunchAgent ${TZ_LAUNCH_AGENT_LABEL}"
}

# Remove the macOS LaunchAgent used for session TZ override
remove_timezone_launch_agent() {
    local gui_domain

    if [ "$(uname -s)" != "Darwin" ]; then
        return 0
    fi

    if ! command -v launchctl > /dev/null 2>&1; then
        print_warning "launchctl not found, skipped macOS session timezone cleanup"
        return 0
    fi

    gui_domain="gui/$(id -u)"
    launchctl bootout "$gui_domain" "$TZ_LAUNCH_AGENT_PATH" > /dev/null 2>&1 || true

    if [ -f "$TZ_LAUNCH_AGENT_PATH" ]; then
        rm -f "$TZ_LAUNCH_AGENT_PATH"
    fi

    launchctl unsetenv TZ > /dev/null 2>&1 || print_warning "Failed to unset launchctl TZ"
}

# Generate a new 64-character lowercase hex userID
generate_user_id() {
    if command -v openssl > /dev/null 2>&1; then
        openssl rand -hex 32
    elif [ -r /dev/urandom ]; then
        od -An -N32 -tx1 /dev/urandom | tr -d ' \n'
    else
        print_error "Failed to generate a new userID"
        exit 1
    fi
}

# Generate a new anonymousId matching Claude Code's current format
generate_anonymous_id() {
    local uuid=""
    local hex=""

    if command -v uuidgen > /dev/null 2>&1; then
        uuid=$(uuidgen | tr '[:upper:]' '[:lower:]')
    elif command -v openssl > /dev/null 2>&1; then
        hex=$(openssl rand -hex 16)
        uuid="${hex:0:8}-${hex:8:4}-${hex:12:4}-${hex:16:4}-${hex:20:12}"
    else
        print_error "Failed to generate a new anonymousId"
        exit 1
    fi

    echo "claudecode.v1.$uuid"
}

# Reset counters and usage statistics
reset_counters() {
    local temp_file=$(mktemp)
    local current_time=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

    jq --arg time "$current_time" '
        if has("numStartups") then .numStartups = 0 else . end
        | if has("btwUseCount") then .btwUseCount = 0 else . end
        | if has("promptQueueUseCount") then .promptQueueUseCount = 0 else . end
        | if has("opus1mMergeNoticeSeenCount") then .opus1mMergeNoticeSeenCount = 0 else . end
        | if has("voiceNoticeSeenCount") then .voiceNoticeSeenCount = 0 else . end
        | if has("firstStartTime") then .firstStartTime = $time else . end
        | if has("claudeCodeFirstTokenDate") then .claudeCodeFirstTokenDate = $time else . end
        | if has("skillUsage") then .skillUsage = {} else . end
        | if has("toolUsage") then .toolUsage = {} else . end
        | if has("tipsHistory") then .tipsHistory |= with_entries(.value = 0) else . end
    ' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Reset numStartups, btwUseCount, promptQueueUseCount, tipsHistory, opus1mMergeNoticeSeenCount, voiceNoticeSeenCount, firstStartTime, claudeCodeFirstTokenDate, skillUsage, and toolUsage"
    else
        rm -f "$temp_file"
        print_error "Failed to reset counters"
        exit 1
    fi
}

# Regenerate identity IDs while preserving the existing userID key style when present
regenerate_identity_ids() {
    local temp_file=$(mktemp)
    local new_user_id
    local new_anonymous_id
    new_user_id=$(generate_user_id)
    new_anonymous_id=$(generate_anonymous_id)

    jq --arg user_id "$new_user_id" --arg anonymous_id "$new_anonymous_id" '
        if has("userID") then
            .userID = $user_id
        elif has("user_id") then
            .user_id = $user_id
        elif has("userId") then
            .userId = $user_id
        else
            .userID = $user_id
        end
        | .anonymousId = $anonymous_id
    ' "$CLAUDE_JSON" > "$temp_file"

    if [ $? -eq 0 ]; then
        mv "$temp_file" "$CLAUDE_JSON"
        print_success "Regenerated userID and anonymousId"
    else
        rm -f "$temp_file"
        print_error "Failed to regenerate identity IDs"
        exit 1
    fi
}

# Set the cccleaner US timezone override in shell files and macOS session
set_us_timezone_override() {
    local file
    local shell_files=(
        "$HOME/.zshenv"
        "$HOME/.zprofile"
        "$HOME/.bash_profile"
        "$HOME/.bashrc"
        "$HOME/.profile"
    )

    for file in "${shell_files[@]}"; do
        if ensure_tz_export_at_top "$file" "$US_TIMEZONE"; then
            print_success "Set US timezone override in $(basename "$file")"
        fi
    done

    if ensure_tz_export_at_end "$HOME/.zshrc" "$US_TIMEZONE"; then
        print_success "Set US timezone override in .zshrc"
    fi

    if [ "$(uname -s)" = "Darwin" ]; then
        write_timezone_launch_agent "$US_TIMEZONE"
        refresh_launchctl_timezone "$US_TIMEZONE"
        print_success "Applied macOS session timezone override"
    fi
}

# Remove the cccleaner timezone override from shell files and macOS session
unset_timezone_override() {
    local file
    local shell_files=(
        "$HOME/.zshenv"
        "$HOME/.zprofile"
        "$HOME/.bash_profile"
        "$HOME/.bashrc"
        "$HOME/.profile"
        "$HOME/.zshrc"
    )

    for file in "${shell_files[@]}"; do
        if remove_tz_exports "$file"; then
            print_success "Removed timezone override from $(basename "$file")"
        fi
    done

    if [ "$(uname -s)" = "Darwin" ]; then
        remove_timezone_launch_agent
        print_success "Removed macOS session timezone override"
    fi
}

# Clear ~/.claude folder contents
clear_claude_folders() {
    local cleaned=0

    # Clear file-history
    if [ -d "$CLAUDE_DIR/file-history" ]; then
        rm -rf "$CLAUDE_DIR/file-history"/*
        print_success "Cleared file-history"
        cleaned=1
    fi

    # Clear projects
    if [ -d "$CLAUDE_DIR/projects" ]; then
        rm -rf "$CLAUDE_DIR/projects"/*
        print_success "Cleared projects"
        cleaned=1
    fi

    # Clear todos
    if [ -d "$CLAUDE_DIR/todos" ]; then
        rm -rf "$CLAUDE_DIR/todos"/*
        print_success "Cleared todos"
        cleaned=1
    fi

    # Clear shell-snapshots
    if [ -d "$CLAUDE_DIR/shell-snapshots" ]; then
        rm -rf "$CLAUDE_DIR/shell-snapshots"/*
        print_success "Cleared shell-snapshots"
        cleaned=1
    fi

    # Clear statsig
    if [ -d "$CLAUDE_DIR/statsig" ]; then
        rm -rf "$CLAUDE_DIR/statsig"/*
        print_success "Cleared statsig"
        cleaned=1
    fi

    # Clear debug
    if [ -d "$CLAUDE_DIR/debug" ]; then
        rm -rf "$CLAUDE_DIR/debug"/*
        print_success "Cleared debug"
        cleaned=1
    fi

    # Clear session-env
    if [ -d "$CLAUDE_DIR/session-env" ]; then
        rm -rf "$CLAUDE_DIR/session-env"/*
        print_success "Cleared session-env"
        cleaned=1
    fi

    if [ $cleaned -eq 0 ]; then
        print_warning "No folders found to clean"
    fi
}

# Clear history.jsonl
clear_history_jsonl() {
    if [ -f "$CLAUDE_DIR/history.jsonl" ]; then
        > "$CLAUDE_DIR/history.jsonl"
        print_success "Cleared history.jsonl"
    else
        print_warning "history.jsonl not found"
    fi
}

# Clean everything
clean_all() {
    print_info "Performing deep clean..."
    echo

    clear_all_histories
    clear_all_projects
    clear_claude_folders
    clear_cache
    clear_github_repo_paths
    clear_history_jsonl
    reset_counters
    regenerate_identity_ids
    print_success "Deep clean completed!"
}

# Interactive mode
interactive_mode() {
    print_info "Interactive Mode - Select projects to clean"
    echo

    # Get project list
    local projects=($(jq -r '.projects | keys[]' "$CLAUDE_JSON"))

    if [ ${#projects[@]} -eq 0 ]; then
        print_warning "No projects found"
        exit 0
    fi

    echo "Projects:"
    for i in "${!projects[@]}"; do
        local project="${projects[$i]}"
        local history_count=$(jq -r --arg path "$project" '.projects[$path].history | length' "$CLAUDE_JSON")
        echo "  [$((i+1))] $project (${history_count} history items)"
    done
    echo
    echo "Options:"
    echo "  [a] Clean everything"
    echo "  [c] Clear cache"
    echo "  [g] Clear GitHub repository paths"
    echo "  [f] Clear folders (file-history, projects, todos, shell-snapshots, statsig, debug, history.jsonl)"
    echo "  [u] Regenerate userID and anonymousId"
    echo "  [q] Quit"
    echo
    read -p "Enter selection (number/a/c/g/f/u/q): " selection

    case "$selection" in
        a|A)
            read -p "Clean everything? (y/N): " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                clean_all
            else
                print_info "Cancelled"
            fi
            ;;
        c|C)
            read -p "Clear cached data? (y/N): " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                clear_cache
            else
                print_info "Cancelled"
            fi
            ;;
        g|G)
            read -p "Clear GitHub repository paths? (y/N): " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                clear_github_repo_paths
            else
                print_info "Cancelled"
            fi
            ;;
        f|F)
            read -p "Clear ~/.claude folders (file-history, projects, todos, shell-snapshots, statsig, debug, session-env, history.jsonl)? (y/N): " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                clear_claude_folders
                clear_history_jsonl
            else
                print_info "Cancelled"
            fi
            ;;
        u|U)
            read -p "Regenerate userID and anonymousId? (y/N): " confirm
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                regenerate_identity_ids
            else
                print_info "Cancelled"
            fi
            ;;
        q|Q)
            print_info "Exiting"
            exit 0
            ;;
        [0-9]*)
            if [ "$selection" -ge 1 ] && [ "$selection" -le "${#projects[@]}" ]; then
                local project="${projects[$((selection-1))]}"
                echo
                echo "What would you like to do with: $project"
                echo "  [1] Clear history only"
                echo "  [2] Delete project entirely"
                echo "  [q] Cancel"
                read -p "Enter selection: " action

                case "$action" in
                    1)
                        clear_project_history "$project"
                        ;;
                    2)
                        read -p "Delete project entirely? (y/N): " confirm
                        if [[ "$confirm" =~ ^[Yy]$ ]]; then
                            delete_project "$project"
                        else
                            print_info "Cancelled"
                        fi
                        ;;
                    *)
                        print_info "Cancelled"
                        ;;
                esac
            else
                print_error "Invalid selection"
                exit 1
            fi
            ;;
        *)
            print_error "Invalid selection"
            exit 1
            ;;
    esac
}

# Main function
main() {
    local create_backup_flag=true
    local action=""
    local project_path=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_usage
                exit 0
                ;;
            -l|--list)
                check_dependencies
                list_projects
                exit 0
                ;;
            -a|--all)
                action="clear_all"
                shift
                ;;
            -p|--project)
                action="clear_project"
                project_path="$2"
                shift 2
                ;;
            -i|--interactive)
                action="interactive"
                shift
                ;;
            -c|--cache)
                action="clear_cache"
                shift
                ;;
            -g|--github-repos)
                action="clear_github_repos"
                shift
                ;;
            -f|--folders)
                action="clear_folders"
                shift
                ;;
            -u|--user-id)
                action="regenerate_identity_ids"
                shift
                ;;
            --set-us-timezone)
                action="set_timezone"
                shift
                ;;
            --unset-timezone)
                action="unset_timezone"
                shift
                ;;
            --no-backup)
                create_backup_flag=false
                shift
                ;;
            *)
                print_error "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
    done

    # Check dependencies only for actions that touch ~/.claude.json
    case "$action" in
        set_timezone|unset_timezone)
            ;;
        *)
            check_dependencies
            ;;
    esac

    # If no action specified, show usage
    if [ -z "$action" ]; then
        show_usage
        exit 0
    fi

    # Create backup unless disabled
    if [ "$create_backup_flag" = true ]; then
        case "$action" in
            set_timezone|unset_timezone)
                create_timezone_backup
                ;;
            *)
                create_claude_backup
                ;;
        esac
        echo
    fi

    # Execute action
    case "$action" in
        clear_all)
            clean_all
            ;;
        clear_project)
            if [ -z "$project_path" ]; then
                print_error "Project path is required"
                exit 1
            fi
            clear_project_history "$project_path"
            ;;
        interactive)
            interactive_mode
            ;;
        clear_cache)
            clear_cache
            ;;
        clear_github_repos)
            clear_github_repo_paths
            ;;
        clear_folders)
            clear_claude_folders
            clear_history_jsonl
            ;;
        regenerate_identity_ids)
            regenerate_identity_ids
            ;;
        set_timezone)
            set_us_timezone_override
            ;;
        unset_timezone)
            unset_timezone_override
            ;;
        *)
            print_error "Unknown action: $action"
            exit 1
            ;;
    esac

    # Don't print "Done!" for clear_all as it has its own message
    if [ "$action" != "clear_all" ]; then
        print_success "Done!"
    fi
}

# Run main function
main "$@"
